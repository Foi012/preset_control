{
  "name": "preset-control",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "check:parser": "ts-node --transpile-only -P tsconfig.check.json src/preset-easy-toggle/parser.check.ts",
    "check:config": "ts-node --transpile-only -P tsconfig.check.json src/preset-easy-toggle/config.check.ts",
    "check:preset-io": "ts-node --transpile-only -P tsconfig.check.json src/preset-easy-toggle/preset-io.check.ts",
    "check:preset-io-native": "ts-node --transpile-only -P tsconfig.check.json src/preset-easy-toggle/preset-io-native.check.ts",
    "check:store": "ts-node --transpile-only -P tsconfig.check.json src/preset-easy-toggle/store.check.ts",
    "check:chat-normalize": "ts-node --transpile-only -P tsconfig.check.json src/chat-export/normalize.check.ts",
    "check:chat-extract": "ts-node --transpile-only -P tsconfig.check.json src/chat-export/extract.check.ts",
    "check:chat-scan": "ts-node --transpile-only -P tsconfig.check.json src/chat-export/scan.check.ts",
    "check:chat-chapters": "ts-node --transpile-only -P tsconfig.check.json src/chat-export/chapters.check.ts",
    "check:chat-render": "ts-node --transpile-only -P tsconfig.check.json src/chat-export/render.check.ts",
    "check:chat-epub": "ts-node --transpile-only -P tsconfig.check.json src/chat-export/epub.check.ts"
  },
  "browserslist": [
    "defaults and partially supports es6-module"
  ],
  "dependencies": {
    "lodash": "^4.18.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/toastr": "^2.1.43",
    "@types/webpack": "^5.28.5",
    "css-loader": "^7.1.4",
    "postcss": "^8.5.14",
    "postcss-loader": "^8.2.1",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.8",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.6.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "6.0.0-dev.20250807",
    "vue-loader": "^17.4.2",
    "webpack": "^5.106.2",
    "webpack-cli": "^6.0.1"
  }
}
